auto-install-peers=true
strict-peer-dependencies=false

# Install-script trust allowlist.
# Only the following dependencies are permitted to run build/install scripts.
# Any new dependency that needs install scripts must be reviewed and added here
# with a justification in `openspec/`.
onlyBuiltDependencies[]=sharp
onlyBuiltDependencies[]=unrs-resolver
onlyBuiltDependencies[]=fsevents